          <mxGeometry x="75.75" y="7170" width="142.5" height="190" as="geometry" />
        </mxCell>
        <mxCell id="1e1lPeBxb3bEikpPYBq5-954" value="Collector" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;" parent="1" vertex="1">
          <mxGeometry x="252.25" y="7170" width="142.5" height="190" as="geometry" />
