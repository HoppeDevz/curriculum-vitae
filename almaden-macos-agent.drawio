        <mxCell id="1e1lPeBxb3bEikpPYBq5-956" value="Dispatcher" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;" parent="1" vertex="1">
