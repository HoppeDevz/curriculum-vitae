        <mxCell id="1e1lPeBxb3bEikpPYBq5-903" value="&lt;span style=&quot;font-family: Menlo; font-size: 11px;&quot;&gt;2025-05-28T10:13:11&lt;/span&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;" parent="1e1lPeBxb3bEikpPYBq5-901" vertex="1">
