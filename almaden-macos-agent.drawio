font-family: monospace; font-weight: 400; white-space: pre;&quot; class=&quot;hljs-type&quot;&gt;Tables&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot; class=&quot;hljs-type&quot;&gt;GpuMetrics&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;.temperature)&lt;/span&gt;&lt;br style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;        tbl.column(&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot; class=&quot;hljs-type&quot;&gt;Tables&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot; class=&quot;hljs-type&quot;&gt;GpuMetrics&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;.timestamp)&lt;/span&gt;&lt;br style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;    })&lt;/span&gt;&lt;br style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;    &lt;/span&gt;&lt;br style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;try&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt; connection.run(&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot; class=&quot;hljs-string&quot;&gt;&quot;PRAGMA gpu_metrics = 1&quot;&lt;/span&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;)&lt;/span&gt;&lt;br style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;&lt;span style=&quot;font-family: monospace; font-weight: 400; white-space: pre;&quot;&gt;}&lt;/span&gt;&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/pre&gt;&lt;pre data-end=&quot;1494&quot; data-start=&quot;1128&quot; class=&quot;overflow-visible!&quot;&gt;&lt;div class=&quot;contain-inline-size rounded-md border-[0.5px] border-token-border-medium relative bg-token-sidebar-surface-primary&quot;&gt;&lt;div dir=&quot;ltr&quot; class=&quot;overflow-y-auto p-4&quot;&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div dir=&quot;ltr&quot; class=&quot;overflow-y-auto p-4&quot;&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;The&lt;/span&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;code style=&quot;white-space: normal;&quot; data-end=&quot;1528&quot; data-start=&quot;1504&quot;&gt;&lt;b&gt;PRAGMA gpu_metrics = 1&lt;/b&gt;&lt;/code&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;indicates that this table is at&lt;/span&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;strong style=&quot;font-family: Helvetica; white-space: normal;&quot; data-end=&quot;1574&quot; data-start=&quot;1561&quot;&gt;version 1&lt;/strong&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div dir=&quot;ltr&quot; class=&quot;overflow-y-auto p-4&quot;&gt;&lt;span style=&quot;font-family: Helvetica; white-space: normal;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div dir=&quot;ltr&quot; class=&quot;overflow-y-auto p-4&quot;&gt;&lt;h3 style=&quot;white-space: normal;&quot; data-end=&quot;1629&quot; data-start=&quot;1582&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/h3&gt;&lt;h3 style=&quot;white-space: normal;&quot; data-end=&quot;1629&quot; data-start=&quot;1582&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;Example – v2: Add New Column&amp;nbsp;&lt;code data-end=&quot;1629&quot; data-start=&quot;1618&quot;&gt;fan_speed&lt;/code&gt;&lt;/font&gt;&lt;/h3&gt;&lt;p style=&quot;white-space: normal;&quot; data-end=&quot;1708&quot; data-start=&quot;1631&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;In a future version (e.g., v2), we may need to extend the schema. To do this:&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal;&quot; data-end=&quot;1708&quot; data-start=&quot;1631&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/p&gt;&lt;p style=&quot;white-space: normal;&quot; data-end=&quot;1708&quot; data-start=&quot;1631&quot;&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;font-family: Helvetica;&quot;&gt;&lt;b&gt;Migration:&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;static&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;func&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-title function_&quot;&gt;gpu_metrics_tbl_v2&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;_&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-params&quot;&gt;connection&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-type&quot;&gt;Connection&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;throws&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; {&lt;/span&gt;&lt;br style=&quot;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;    &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;let&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; current_version &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-operator&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;try&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; connection.pragmaValue(&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-string&quot;&gt;&quot;gpu_metrics&quot;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;) &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-keyword&quot;&gt;as?&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-type&quot;&gt;Int&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-operator&quot;&gt;??&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot; class=&quot;hljs-number&quot;&gt;0&lt;/span&gt;&lt;br style=&quot;white-space: pre;&quot;&gt;&lt;br style=&quot;white-space: pre;&quot;&gt;&lt;span style=&quot;white-space: pre